repositories:
  - name: jetstack
    url: https://charts.jetstack.io

releases:
  - name: cert-manager
    namespace: {{ .Values.certManager.namespace }}
    createNamespace: true
    chart: jetstack/cert-manager
    version: {{ .Values.certManager.version }}
    values:
{{ toYaml .Values.certManager.values | nindent 6 }}
